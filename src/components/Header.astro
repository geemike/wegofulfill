---
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services/', label: 'Services' },
  { href: '/resources/', label: 'Resources' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
];
---
<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="WegoFulfill Home">
      <span class="logo-text">Wego<span class="logo-accent">Fulfill</span></span>
    </a>
    <nav class="nav" aria-label="Main navigation">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <a href="/contact/" class="btn btn-primary nav-cta-mobile">Get a Quote</a>
    </nav>
    <a href="/contact/" class="btn btn-primary header-cta">Get a Quote</a>
    <button class="mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(10px);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    padding-bottom: 1rem;
    gap: 1.5rem;
  }
  .logo { text-decoration: none; flex-shrink: 0; }
  .logo-text { font-size: 1.5rem; font-weight: 800; color: var(--color-primary-dark); }
  .nav { display: flex; align-items: center; }
  .nav-list { display: flex; gap: 0.25rem; list-style: none; margin: 0; padding: 0; }
  .nav-link {
    display: block;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition);
    white-space: nowrap;
  }
  .nav-link:hover, .nav-link.active { color: var(--color-primary); background: var(--color-bg-alt); }
  .nav-link.active { font-weight: 600; }
  .header-cta { padding: 10px 28px; font-size: 0.9rem; border-radius: 100px; font-weight: 700; background: #2563eb; box-shadow: 0 4px 12px rgba(37, 99, 235,0.25); flex-shrink: 0; white-space: nowrap; text-decoration: none; color: #fff; }
  .nav-cta-mobile { display: none; }
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    z-index: 1001;
    flex-shrink: 0;
  }
  .mobile-toggle span { display: block; width: 24px; height: 2px; background: var(--color-text); border-radius: 2px; transition: all 0.3s; }

  /* ===== Mobile ===== */
  @media (max-width: 900px) {
    .header-inner { gap: 0.5rem; }
    .nav {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--color-bg);
      flex-direction: column;
      justify-content: center;
      align-items: center;
      z-index: 1000;
      padding: 2rem;
    }
    .nav.open { display: flex; }
    .nav .nav-list {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .nav .nav-link {
      font-size: 1.3rem;
      padding: 0.75rem 1.5rem;
    }
    .nav-cta-mobile {
      display: inline-flex;
      margin-top: 2rem;
      padding: 12px 32px;
      font-size: 1rem;
      border-radius: 100px;
      font-weight: 700;
      background: #2563eb;
      color: #fff;
      text-decoration: none;
    }
    .header-cta { display: none; }
    .mobile-toggle { display: flex; }
  }
</style>
<script>
  const toggle = document.querySelector('.mobile-toggle');
  const nav = document.querySelector('.nav');
  const body = document.body;
  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    if (isOpen) {
      body.style.overflow = 'hidden';
      toggle.querySelectorAll('span').forEach((s, i) => {
        if (i === 0) { s.style.transform = 'rotate(45deg) translate(5px, 5px)'; }
        else if (i === 1) { s.style.opacity = '0'; }
        else { s.style.transform = 'rotate(-45deg) translate(5px, -5px)'; }
      });
    } else {
      body.style.overflow = '';
      toggle.querySelectorAll('span').forEach(s => {
        s.style.transform = ''; s.style.opacity = '';
      });
    }
  });
</script>