---
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services/', label: 'Services' },
  { href: '/resources/', label: 'Resources' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
];
---
<header class="header">
  <div class="container header-inner">
    <button class="mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <a href="/" class="logo" aria-label="WegoFulfill Home">
      <span class="logo-text">Wego<span class="logo-accent">Fulfill</span></span>
    </a>
    <nav class="nav" aria-label="Main navigation">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <a href="/contact/" class="btn btn-primary header-cta">Get a Quote</a>
    <a href="/contact/" class="btn btn-primary header-cta-mob">Quote</a>
  </div>
</header>
<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
    gap: 1.5rem;
    position: relative;
  }
  .logo { text-decoration: none; flex-shrink: 0; }
  .logo-text { font-size: 1.5rem; font-weight: 800; color: var(--color-primary-dark); }
  .nav { margin-left: auto; }
  .nav-list { display: flex; gap: 0.25rem; list-style: none; margin: 0; padding: 0; }
  .nav-link {
    display: block;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition);
    white-space: nowrap;
  }
  .nav-link:hover, .nav-link.active { color: var(--color-primary); background: var(--color-bg-alt); }
  .nav-link.active { font-weight: 600; }
  .header-cta {
    padding: 10px 28px;
    font-size: 0.9rem;
    border-radius: 100px;
    font-weight: 700;
    background: #2563eb;
    color: #fff;
    text-decoration: none;
    flex-shrink: 0;
    white-space: nowrap;
    box-shadow: 0 4px 12px rgba(37, 99, 235,0.25);
  }
  .mobile-toggle { display: none; }
  .header-cta-mob { display: none; }

  @media (max-width: 900px) {
    .header-inner { gap: 1rem; }
    .mobile-toggle {
      display: flex;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      flex-shrink: 0;
      z-index: 1001;
    }
    .mobile-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--color-text);
      border-radius: 2px;
      transition: all 0.3s;
    }
    .logo { flex: 1; text-align: center; }
    .nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      padding: 1rem;
      margin: 0;
    }
    .nav.open { display: block; }
    .nav .nav-list { flex-direction: column; gap: 0; }
    .nav .nav-link {
      font-size: 1.05rem;
      padding: 0.85rem 1rem;
      border-radius: 8px;
    }
    .header-cta { display: none; }
    .header-cta-mob {
      display: inline-flex;
      padding: 8px 16px;
      font-size: 0.8rem;
      border-radius: 100px;
      font-weight: 700;
      background: #2563eb;
      color: #fff;
      text-decoration: none;
      flex-shrink: 0;
      white-space: nowrap;
    }
  }
</style>
<script>
  const toggle = document.querySelector('.mobile-toggle');
  const nav = document.querySelector('.nav');
  toggle?.addEventListener('click', () => {
    nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(nav?.classList.contains('open')));
  });
</script>