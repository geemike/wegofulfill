---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import InquiryForm from '../../components/InquiryForm.astro';
import { products } from '../../data/products';
---

<BaseLayout
  title="China Fulfillment Services - Sourcing, QC, Shipping from Shenzhen"
  description="WegoFulfill provides comprehensive China fulfillment services: product sourcing, warehousing & storage, quality control (QC), pick & pack fulfillment, global shipping, and returns management. No MOQ, no monthly fees. Based in Shenzhen, China."
  keywords="China fulfillment services, product sourcing China, quality control inspection, Shenzhen warehouse, pick and pack China, global shipping from China, dropshipping fulfillment, 3PL China"
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Services', url: '/services/' }]}
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="section">
    <div class="container">
      <div class="section-title">
        <h1>Our Core Services</h1>
        <p>From sourcing products in China to delivering them to your customers' doorsteps globally. We handle the logistics so you can focus on marketing.</p>
      </div>

      <div class="grid-3">
        {products.map(product => (
          <a href={`/services/${product.slug}/`} class="service-card">
            <div class="service-icon" set:html={product.icon} />
            <h3>{product.title}</h3>
            <p>{product.shortDesc}</p>
            <div class="service-features">
              {product.features.map(f => (
                <span class="sf-tag">{f.title}</span>
              ))}
            </div>
            <span class="card-link">Learn More &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Build Your Brand -->
  <section class="section section-alt">
    <div class="container">
      <div class="brand-section">
        <div class="brand-content">
          <h2>Build Your Brand, Not Just A Store</h2>
          <p>We offer comprehensive private labeling services even for small volumes. Differentiate yourself from competitors with custom packaging.</p>
          <div class="brand-tags">
            <span>&#128230; Custom Boxes</span>
            <span>&#128140; Thank You Cards</span>
            <span>&#127991;&#65039; Stickers</span>
            <span>&#127991; Hang Tags</span>
            <span>&#128278; Custom Tape</span>
          </div>
        </div>
        <div class="brand-icon-lg">&#127873;</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container cta-inner">
      <h2>Ready to Scale Your Business?</h2>
      <p>Get a free quote today. No credit card required.</p>
      <a href="/contact/" class="btn btn-primary">Get a Free Quote</a>
    </div>
  </section>

  <InquiryForm />
  <Footer slot="footer" />
</BaseLayout>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all var(--transition);
  }
  .service-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    color: inherit;
  }
  .service-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .service-card h3 { margin-bottom: 0.5rem; font-size: 1.1rem; }
  .service-card > p { color: var(--color-text-light); font-size: 0.9rem; flex-grow: 1; }
  .service-features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1rem 0;
  }
  .sf-tag {
    background: var(--color-bg-alt);
    padding: 0.2rem 0.6rem;
    border-radius: 50px;
    font-size: 0.75rem;
    color: var(--color-text-light);
  }
  .card-link {
    display: inline-block;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--color-accent);
  }

  /* Brand Section */
  .brand-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .brand-content h2 { margin-bottom: 1rem; }
  .brand-content p { color: var(--color-text-light); margin-bottom: 1.5rem; line-height: 1.7; }
  .brand-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .brand-tags span {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .brand-icon-lg {
    font-size: 8rem;
    text-align: center;
    line-height: 1;
  }

  /* CTA */
  .cta-section { padding: 0 0 4rem; }
  .cta-inner {
    text-align: center;
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
    color: #fff;
    padding: 3rem;
    border-radius: var(--radius);
  }
  .cta-inner h2 { color: #fff; margin-bottom: 0.75rem; }
  .cta-inner p { color: rgba(255,255,255,0.85); margin-bottom: 1.5rem; }
  .cta-inner .btn-primary { padding: 0.85rem 2.5rem; font-size: 1.05rem; border-radius: 50px; }

  @media (max-width: 768px) {
    .brand-section { grid-template-columns: 1fr; }
    .brand-icon-lg { font-size: 4rem; }
  }
  @media (max-width: 576px) {
    .section-title h1 { font-size: 1.5rem; }
  }
</style>
