---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InquiryForm from '../components/InquiryForm.astro';
---

<BaseLayout
  title="China Dropshipping Agent & Fulfillment Partner for Overseas Sellers"
  description="WegoFulfill is a China-based dropshipping agent and 3PL fulfillment partner. We source directly from Chinese factories, inspect quality, pick-pack-ship from Shenzhen, and deliver globally in 5-10 days."
  keywords="China dropshipping agent, China fulfillment center, dropshipping from China, factory-direct sourcing agent, China 3PL, Shenzhen fulfillment"
>
  <Header slot="header" />

  <!-- 1. Hero -->
  <section class="hero-section">
    <div class="container">
      <span class="hero-badge">China Fulfillment Partner</span>
      <h1>China Dropshipping Agent<br>for Overseas Sellers</h1>
      <p>Reliable sourcing, packing &amp; shipping. No MOQ, fast handling, and clear pricing.</p>
      <a href="#quote-form" class="btn btn-primary hero-cta">Get a Free Quote</a>
    </div>
  </section>

  <!-- 2. Stats Bar -->
  <section class="section stats-section">
    <div class="container">
      <div class="stats-bar">
        <div class="stat-item"><strong>No MOQ</strong><span>Test products freely</span></div>
        <div class="stat-item"><strong>1-2 Days</strong><span>Processing Time</span></div>
        <div class="stat-item"><strong>5-10 Days</strong><span>Fast Global Shipping</span></div>
        <div class="stat-item"><strong>90 Days</strong><span>Free Storage</span></div>
      </div>
    </div>

  </section>
  <!-- 3. Logistics & Integration -->
  <section class="section">
    <div class="container">
      <div class="section-title">
        <span class="overline">Average Shipping Time (Fast Lines)</span>
      </div>
      <div class="shipping-grid">
        <div class="shipping-card"><span class="flag">🇺🇸</span><span class="country">USA</span><span class="days">5-8 <small>Days</small></span></div>
        <div class="shipping-card"><span class="flag">🇬🇧</span><span class="country">UK</span><span class="days">4-6 <small>Days</small></span></div>
        <div class="shipping-card"><span class="flag">🇩🇪</span><span class="country">Germany</span><span class="days">5-8 <small>Days</small></span></div>
        <div class="shipping-card"><span class="flag">🇫🇷</span><span class="country">France</span><span class="days">5-8 <small>Days</small></span></div>
        <div class="shipping-card"><span class="flag">🇦🇺</span><span class="country">Australia</span><span class="days">6-9 <small>Days</small></span></div>
        <div class="shipping-card"><span class="flag">🇨🇦</span><span class="country">Canada</span><span class="days">7-10 <small>Days</small></span></div>
      </div>

      <div class="section-title" style="margin-top:3rem;">
        <span class="overline">Trusted Logistics Partners</span>
      </div>
      <div class="partner-tags">
        <span class="partner-tag">YunExpress</span>
        <span class="partner-tag">WanbExpress</span>
        <span class="partner-tag">Yanwen</span>
        <span class="partner-tag">4PX</span>
        <span class="partner-tag">DHL</span>
        <span class="partner-tag">FedEx</span>
      </div>

      <div class="section-title" style="margin-top:3rem;">
        <span class="overline">Seamless Store Integration</span>
      </div>
      <div class="partner-logos">
        <img src="/images/shopify-logo.svg" alt="Shopify" title="Shopify" />
        <img src="/images/woocommerce-logo.svg" alt="WooCommerce" title="WooCommerce" />
        <img src="/images/tiktok-logo.svg" alt="TikTok Shop" title="TikTok Shop" />
        <img src="/images/amazon-logo.svg" alt="Amazon" title="Amazon" />
        <img src="/images/ebay-logo.svg" alt="eBay" title="eBay" />
      </div>
    </div>
  </section>

  <!-- 4. How It Works -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-title">
        <h2>How It Works</h2>
        <p>Seamless integration. You don&rsquo;t need to integrate anything before you see the price.</p>
      </div>
      <div class="steps-grid">
        <div class="step-card"><div class="step-num">01</div><h3>Send Product Details</h3><p>Send product images or links (Shopify, WooCommerce, TikTok, etc.), plus target country and daily volume.</p></div>
        <div class="step-card"><div class="step-num">02</div><h3>Get a Clear Quote</h3><p>We provide a clear per-SKU, per-order cost, including product price, fulfillment handling, and shipping &mdash; so <b>you know your margin before scaling</b>.</p></div>
        <div class="step-card"><div class="step-num">03</div><h3>Confirm Orders</h3><p>After confirmation, you can start sending orders to us &mdash; manually or via store integration.</p></div>
        <div class="step-card"><div class="step-num">04</div><h3>Source &amp; Inspect</h3><p>We source the products, inspect quality (QC), and perform repacking or custom packaging as required.</p></div>
        <div class="step-card"><div class="step-num">05</div><h3>Fulfill &amp; Ship</h3><p>Orders are picked, packed, and shipped from China using reliable global carriers.</p></div>
        <div class="step-card"><div class="step-num">06</div><h3>Track &amp; Support</h3><p>Tracking numbers are auto-synced. Our team assists with reshipments, returns, or customer issues.</p></div>
      </div>
    </div>
  </section>

  <!-- 5. Comparison Table -->
  <section class="section">
    <div class="container">
      <div class="section-title">
        <h2>Why Choose WegoFulfill?</h2>
        <p>See how we compare to standard AliExpress dropshipping.</p>
      </div>
      <div class="compare-wrap">
        <table class="compare-table">
          <thead>
            <tr><th>Feature</th><th class="col-us">WegoFulfill</th><th>AliExpress / Others</th></tr>
          </thead>
          <tbody>
            <tr><td>Pricing Structure</td><td class="col-us"><span class="check">&#10004; Transparent, All-inclusive</span></td><td><span class="cross">&#10008; Hidden Fees</span></td></tr>
            <tr><td>Customer Support</td><td class="col-us"><span class="check">&#10004; Priority Support Whatsapp + Discord</span></td><td><span class="cross">&#10008; Slow Email Response</span></td></tr>
            <tr><td>Inventory Management</td><td class="col-us"><span class="check">&#10004; Real-time Tracking</span></td><td><span class="cross">&#10008; Manual / Delayed</span></td></tr>
            <tr><td>Warehousing</td><td class="col-us"><span class="check">&#10004; Base China Shenzhen</span></td><td><span class="cross">&#10008; CJDropshipping, DSers</span></td></tr>
            <tr><td>Branding Services</td><td class="col-us"><span class="check">&#10004; Custom Logos &amp; Inserts</span></td><td><span class="cross">&#10008; Generic Packaging</span></td></tr>
            <tr><td>Returns &amp; Exchanges</td><td class="col-us"><span class="check">&#10004; Easy Returns Labels</span></td><td><span class="cross">&#10008; Difficult / No Returns</span></td></tr>
            <tr><td>Scalability</td><td class="col-us"><span class="check">&#10004; Flexible &amp; Scalable</span></td><td><span class="cross">&#10008; Rigid / High MOQ</span></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- 6. Core Services -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-title">
        <h2>Our Core Services</h2>
        <p>You focus on selling. We handle the rest in China.</p>
      </div>
      <div class="grid-3">
        <div class="card service-card-item"><span class="service-icon">&#128269;</span><h3>Product Sourcing</h3><p><strong>You don&rsquo;t need to compare, or negotiate with Chinese suppliers.</strong> Send us a product link or image &mdash; we handle supplier communication, real cost confirmation, and availability checks.</p></div>
        <div class="card service-card-item"><span class="service-icon">&#9989;</span><h3>Quality Control</h3><p>We inspect products before shipping and handle repacking to reduce disputes and returns.</p></div>
        <div class="card service-card-item"><span class="service-icon">&#128230;</span><h3>Order Fulfillment</h3><p>We pick, pack, and ship each order from our China warehouse, whether it&rsquo;s 5 or 500 orders a day.</p></div>
        <div class="card service-card-item"><span class="service-icon">&#9992;&#65039;</span><h3>International Shipping</h3><p>We select reliable routes (YunExpress, CNE, etc.), provide clear costs, and ensure tracking.</p></div>
        <div class="card service-card-item"><span class="service-icon">&#128225;</span><h3>Store Integration</h3><p>Orders can be sent manually or synced from your store, with tracking numbers automatically updated.</p></div>
        <div class="card service-card-item"><span class="service-icon">&#128176;</span><h3>After-sales Support</h3><p>We assist with reshipments, returns, and lost or damaged parcels &mdash; so you can stay focused on growth.</p></div>
      </div>
    </div>
  </section>

  <!-- 7. Every Parcel is A Promise -->
  <section class="section">
    <div class="container">
      <div class="promise-split">
        <div class="promise-text">
          <h2>Every Parcel is A Promise</h2>
          <p>Most of our clients started with just a few orders per day. We work hands-on with sourcing and fulfillment.</p>
          <ul class="promise-list">
            <li><strong>Based in China:</strong> Direct access to factories and supply chain.</li>
            <li><strong>Comprehensive 3PL:</strong> Pick &amp; pack, shipping, and customs clearance.</li>
            <li><strong>Scalable:</strong> Daily capacity up to 1,000+ orders.</li>
            <li><strong>Flexible:</strong> Multiple SKUs and mixed orders handled daily.</li>
          </ul>
        </div>
        <div class="promise-img">
          <img src="/images/wegofulfill-team.jpg" alt="WegoFulfill Team" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- 8. FAQ -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-title">
        <h2>Frequently Asked Questions</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item"><summary>Do you have a monthly fee?</summary><div class="faq-answer">No. We don&rsquo;t charge any monthly or subscription fees. You only pay per order.</div></details>
        <details class="faq-item"><summary>Is there a Minimum Order Quantity (MOQ)?</summary><div class="faq-answer">No MOQ. Many of our clients start with just a few orders per day and scale gradually.</div></details>
        <details class="faq-item"><summary>How do I pay?</summary><div class="faq-answer">We support PayPal, Payoneer, and Wise.</div></details>
        <details class="faq-item"><summary>Can you handle multiple SKUs or mixed orders?</summary><div class="faq-answer">Yes. We handle multiple SKUs, mixed orders, and bundled shipments on a daily basis.</div></details>
      </div>
    </div>
  </section>

  <!-- 9. Free Resources -->
  <section class="section">
    <div class="container">
      <div class="section-title">
        <h2>Free Resources for Dropshippers</h2>
        <p>Guides, comparisons, and case studies to help you scale your e-commerce business.</p>
      </div>
      <div class="grid-3">
        <a href="/guides/" class="card resource-card resource-guides">
          <div class="resource-icon">&#128214;</div>
          <h3>Guides</h3>
          <p>Step-by-step tutorials on dropshipping from China, Shopify fulfillment, Single SKU strategies, and scaling your store.</p>
          <span class="resource-count">4 articles</span>
          <span class="resource-link">Browse Guides &rarr;</span>
        </a>
        <a href="/comparisons/" class="card resource-card resource-comparisons">
          <div class="resource-icon">&#9878;&#65039;</div>
          <h3>Comparisons</h3>
          <p>Head-to-head data on CJdropshipping, HyperSKU, and private agents. Make informed fulfillment decisions.</p>
          <span class="resource-count">3 articles</span>
          <span class="resource-link">Browse Comparisons &rarr;</span>
        </a>
        <a href="/case-studies/" class="card resource-card resource-cases">
          <div class="resource-icon">&#128202;</div>
          <h3>Case Studies</h3>
          <p>Real stores that scaled from 50 to 500+ orders/day. See strategies, data, and lessons learned.</p>
          <span class="resource-count">3 articles</span>
          <span class="resource-link">Browse Case Studies &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 10. Inquiry Form -->
  <InquiryForm />

  <!-- Dataset Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org","@type":"Dataset",
    "name":"WegoFulfill vs AliExpress Dropshipping Comparison",
    "description":"Side-by-side comparison of WegoFulfill fulfillment vs standard AliExpress dropshipping across 7 key dimensions.",
    "url":"https://www.wegofulfill.com/",
    "creator":{"@type":"Organization","name":"WegoFulfill","url":"https://www.wegofulfill.com"},
    "variableMeasured":[
      {"@type":"PropertyValue","name":"Pricing","value":"Transparent all-inclusive vs Hidden fees"},
      {"@type":"PropertyValue","name":"Shipping Speed","value":"5-10 Days vs 15-30 Days"},
      {"@type":"PropertyValue","name":"Quality Control","value":"100% Inspection vs None"},
      {"@type":"PropertyValue","name":"Branding","value":"Available vs Not Available"},
      {"@type":"PropertyValue","name":"Support","value":"WhatsApp/Discord vs Ticket System"},
      {"@type":"PropertyValue","name":"Monthly Fee","value":"None vs Varies"},
      {"@type":"PropertyValue","name":"MOQ","value":"No Minimum vs Often Required"}
    ]
  })} />

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ===== Hero ===== */
  .hero-section {
    background: radial-gradient(circle at top, var(--color-bg-alt) 0%, var(--color-bg) 70%);
    text-align: center;
    padding: 5rem 0 6rem;
    border-radius: 0 0 40px 40px;
    margin-bottom: 0;
  }
  .hero-badge {
    display: inline-block;
    background: #dbeafe;
    color: var(--color-primary);
    padding: 5px 15px;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }
  .hero-section h1 {
    font-size: 3.25rem;
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }
  .hero-section p {
    font-size: 1.2rem;
    color: var(--color-text-light);
    max-width: 700px;
    margin: 0 auto 2rem;
  }
  .hero-cta {
    font-size: 1rem;
    padding: 14px 32px;
  }

  /* ===== Stats Bar ===== */
  .stats-section { padding-top: 0; padding-bottom: 0; }
.section-flush { padding-top: 0; }
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-top: -50px;
    background: var(--color-bg);
    border-radius: 12px;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
    position: relative;
    z-index: 10;
  }
  .stat-item {
    text-align: center;
    padding: 1.75rem 1rem;
    border-right: 1px solid var(--color-border);
  }
  .stat-item:last-child { border-right: none; }
  .stat-item strong { display: block; font-size: 1.6rem; color: var(--color-primary); font-weight: 800; margin-bottom: 0.25rem; }
  .stat-item span { font-size: 0.85rem; color: var(--color-text-light); }

  /* ===== Overline ===== */
  .overline {
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 1.2px; color: #94a3b8;
  }
  .overline::before, .overline::after {
    content: ""; display: inline-block; width: 40px; height: 1px;
    background: var(--color-border); vertical-align: middle; margin: 0 15px;
  }

  /* ===== Shipping ===== */
  .shipping-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 15px; margin-top: 1.5rem; }
  .shipping-card {
    background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 12px;
    padding: 20px 15px; text-align: center; transition: all var(--transition);
    box-shadow: var(--shadow-sm);
  }
  .shipping-card:hover { transform: translateY(-4px); border-color: var(--color-primary); box-shadow: var(--shadow-lg); }
  .flag { font-size: 1.8rem; display: block; margin-bottom: 8px; }
  .country { font-size: 0.85rem; color: var(--color-text-light); font-weight: 600; display: block; margin-bottom: 4px; }
  .days { font-size: 1.15rem; font-weight: 800; }
  .days small { font-size: 0.8rem; font-weight: 400; color: #94a3b8; }

  /* ===== Partner Tags ===== */
  .partner-tags { display: flex; justify-content: center; flex-wrap: wrap; gap: 12px; margin-top: 1.5rem; }
  .partner-tag {
    font-weight: 700; color: var(--color-text-light); font-size: 0.9rem;
    text-transform: uppercase; letter-spacing: 0.5px;
    background: var(--color-bg-alt); border: 1px solid var(--color-border);
    padding: 10px 20px; border-radius: 8px; transition: all var(--transition);
  }
  .partner-tag:hover { color: var(--color-primary); border-color: var(--color-primary); background: #dbeafe; transform: translateY(-2px); }

  /* ===== Partner Logos ===== */
  .partner-logos { display: flex; justify-content: center; align-items: center; flex-wrap: wrap; gap: 25px; margin-top: 1.5rem; }
  .partner-logos img { height: 40px; width: auto; transition: all var(--transition); }
  .partner-logos img:hover { transform: scale(1.1); }

  /* ===== Steps Grid ===== */
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .step-card {
    background: var(--color-bg); padding: 2rem; border-radius: 12px;
    border: 1px solid var(--color-border); position: relative; overflow: hidden;
    transition: all var(--transition); box-shadow: var(--shadow-sm);
  }
  .step-card:hover { border-color: var(--color-primary); box-shadow: var(--shadow-lg); transform: translateY(-4px); }
  .step-num { font-size: 3rem; color: var(--color-bg-alt); font-weight: 900; position: absolute; top: -5px; right: 20px; line-height: 1; }
  .step-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .step-card p { font-size: 0.9rem; color: var(--color-text-light); line-height: 1.6; margin-bottom: 0; }

  /* ===== Comparison Table ===== */
  .compare-wrap { overflow-x: auto; border-radius: 12px; box-shadow: var(--shadow-md); border: 1px solid var(--color-border); }
  .compare-table { width: 100%; border-collapse: collapse; background: var(--color-bg); min-width: 700px; }
  .compare-table th, .compare-table td { padding: 18px 20px; text-align: center; border-bottom: 1px solid var(--color-border); font-size: 0.95rem; }
  .compare-table th { background: var(--color-bg-alt); font-weight: 700; }
  .compare-table td:first-child { text-align: left; font-weight: 600; }
  .col-us { background: var(--color-bg-alt); color: var(--color-primary); font-weight: 700; border-left: 2px solid var(--color-primary); border-right: 2px solid var(--color-primary); }
  .check { color: #16a34a; font-weight: 700; }
  .cross { color: #dc2626; }

  /* ===== Service Cards ===== */
  .service-card-item { padding: 2rem; border: 2px solid transparent; text-align: left; }
  .service-card-item:hover { border-color: var(--color-border); }
  .service-icon { font-size: 2rem; margin-bottom: 1rem; display: block; }
  .service-card-item h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .service-card-item p { color: var(--color-text-light); font-size: 0.9rem; line-height: 1.6; margin-bottom: 0; }

  /* ===== Promise Split ===== */
  .promise-split { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .promise-text h2 { font-size: 2rem; font-weight: 800; margin-bottom: 1rem; }
  .promise-text > p { color: var(--color-text-light); margin-bottom: 1.5rem; line-height: 1.7; }
  .promise-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .promise-list li { line-height: 1.7; }
  .promise-list li strong { color: var(--color-bg-dark); }
  .promise-img img { width: 100%; border-radius: 12px; }

  /* ===== FAQ ===== */
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { border: 1px solid var(--color-border); border-radius: 10px; margin-bottom: 10px; overflow: hidden; transition: all var(--transition); background: var(--color-bg); }
  .faq-item:hover { border-color: var(--color-primary); }
  .faq-item summary { padding: 18px 24px; font-weight: 600; font-size: 1rem; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: "+"; font-size: 1.3rem; color: var(--color-primary); font-weight: 700; }
  .faq-item[open] summary::after { content: "\2212"; }
  .faq-item[open] { border-color: var(--color-primary); box-shadow: var(--shadow-sm); }
  .faq-answer { padding: 0 24px 18px; color: var(--color-text-light); line-height: 1.7; font-size: 0.95rem; }

  /* ===== Resource Cards ===== */
  .resource-card { display: flex; flex-direction: column; padding: 2rem; color: inherit; }
  .resource-card:hover { color: inherit; }
  .resource-icon { font-size: 2.25rem; margin-bottom: 1rem; }
  .resource-card h3 { font-size: 1.15rem; margin-bottom: 0.5rem; }
  .resource-card p { color: var(--color-text-light); font-size: 0.9rem; line-height: 1.7; flex-grow: 1; }
  .resource-count { display: inline-block; margin-top: 1rem; font-size: 0.8rem; color: var(--color-text-light); background: var(--color-bg-alt); padding: 0.25rem 0.75rem; border-radius: 50px; }
  .resource-link { display: inline-block; margin-top: 0.5rem; font-weight: 600; font-size: 0.85rem; color: var(--color-primary); }
  .resource-guides:hover { border-color: var(--color-primary); }
  .resource-comparisons:hover { border-color: #8b5cf6; }
  .resource-cases:hover { border-color: #059669; }

  /* ===== Responsive ===== */
  @media (max-width: 992px) {
    .shipping-grid { grid-template-columns: repeat(3, 1fr); }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .promise-split { grid-template-columns: 1fr; gap: 2rem; }
  }
  @media (max-width: 768px) {
    .hero-section h1 { font-size: 2.2rem; }
    .stats-bar { grid-template-columns: repeat(2, 1fr); }
    .stat-item { border-bottom: 1px solid var(--color-border); }
    .stat-item:nth-child(3), .stat-item:nth-child(4) { border-bottom: none; }
    .stat-item:nth-child(even) { border-right: none; }
    .shipping-grid { grid-template-columns: repeat(2, 1fr); }
    .partner-logos img { height: 32px; }
  }
  @media (max-width: 576px) {
    .hero-section h1 { font-size: 1.75rem; }
    .hero-section { padding: 3rem 0 4rem; }
    .stats-bar { grid-template-columns: 1fr; }
    .stat-item { border-right: none; }
    .stat-item:nth-child(3) { border-bottom: 1px solid var(--color-border); }
    .steps-grid { grid-template-columns: 1fr; }
    .shipping-grid { grid-template-columns: repeat(2, 1fr); }
    .partner-logos { gap: 15px; }
    .partner-logos img { height: 28px; }
  }
</style>
