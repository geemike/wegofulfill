---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import InquiryForm from '../../components/InquiryForm.astro';
import { caseStudies } from '../../data/case-studies';
---

<BaseLayout
  title="Case Studies - Real Shopify Stores Using China Fulfillment"
  description="Real-world case studies of dropshipping and e-commerce stores that scaled their business using China fulfillment. Learn how sellers achieved growth with WegoFulfill's sourcing, QC, and shipping services."
  keywords="dropshipping case study, Shopify fulfillment success story, China fulfillment case study, ecommerce growth story, phone accessories fulfillment, scaling Shopify store"
>
  <Header slot="header" />

  <section class="section">
    <div class="container">
      <div class="section-title">
        <h1>Case Studies</h1>
        <p>Real stories of stores that scaled with China fulfillment</p>
      </div>

      <div class="grid-2">
        {caseStudies.map(cs => (
          <a href={`/case-studies/${cs.slug}/`} class="card content-card">
            <div class="content-img-placeholder">
              <span>&#128202; Case Study</span>
            </div>
            <div class="card-body">
              <div class="content-meta">
                <span>{cs.date}</span>
                <span>{cs.readTime}</span>
                <span class="content-category">{cs.category}</span>
              </div>
              <h3>{cs.title}</h3>
              <p>{cs.description}</p>
              <span class="card-link">Read Case Study &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <InquiryForm />
  <Footer slot="footer" />
</BaseLayout>

<style>
  .content-card {
    border: 1px solid var(--color-border);
    transition: all var(--transition);
  }
  .content-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    color: inherit;
  }
  .content-img-placeholder {
    height: 160px;
    background: linear-gradient(135deg, #059669, #10b981);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 600;
    font-size: 1.1rem;
  }
  .content-meta {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-text-light);
    flex-wrap: wrap;
  }
  .content-category {
    background: rgba(249,115,22,0.1);
    color: var(--color-accent);
    padding: 0.15rem 0.6rem;
    border-radius: 50px;
    font-weight: 600;
  }
  .card-body h3 { margin-bottom: 0.5rem; font-size: 1.05rem; }
  .card-body p { color: var(--color-text-light); font-size: 0.9rem; margin-bottom: 0; }
  .card-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--color-accent);
  }
  @media (max-width: 576px) {
    .content-img-placeholder { height: 140px; }
  }
</style>
