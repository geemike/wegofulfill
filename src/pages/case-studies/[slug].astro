---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import InquiryForm from '../../components/InquiryForm.astro';
import { caseStudies } from '../../data/case-studies';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';

export function getStaticPaths() {
  return caseStudies.map(cs => ({
    params: { slug: cs.slug },
    props: { cs },
  }));
}

const { cs } = Astro.props;
const relatedCases = caseStudies.filter(c2 => c2.slug !== cs.slug).slice(0, 3);
---

<BaseLayout
  title={cs.title}
  description={cs.description}
  keywords={`dropshipping case study, ${cs.title}, fulfillment success story, ecommerce growth, China fulfillment results`}
  pageType="article"
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Case Studies', url: '/case-studies/' }, { name: cs.title, url: '/case-studies/' + cs.slug + '/' }]}
  schema={[articleSchema({ title: cs.title, description: cs.excerpt, path: '/case-studies/' + cs.slug + '/' })]}
>
  <Header slot="header" />

  <article class="section">
    <div class="container content-container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> &rsaquo; <a href="/case-studies/">Case Studies</a> &rsaquo; <span>{cs.title}</span>
      </nav>

      <header class="content-header">
        <div class="content-meta">
          <span>{cs.date}</span>
          <span>{cs.readTime}</span>
          <span class="content-category">{cs.category}</span>
        </div>
        <h1>{cs.title}</h1>
        <p class="content-desc">{cs.description}</p>
        <span class="content-author">By {cs.author}</span>
      </header>

      <div class="content-body" set:html={cs.content} />
    </div>
  </article>

  <RelatedLinks items={relatedCases.map(c2 => ({ slug: c2.slug, title: c2.title, description: c2.excerpt, category: 'Case Study' }))} basePath="/case-studies/" title="More Case Studies" />
  <InquiryForm
    title="Ready to Write Your Own Success Story?"
    subtitle="Send us your product details and get a free fulfillment quote."
  />

  <!-- Article JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": cs.title,
    "description": cs.description,
    "datePublished": cs.date,
    "articleSection": "Case Studies",
    "author": {
      "@type": "Organization",
      "name": cs.author
    },
    "publisher": {
      "@type": "Organization",
      "name": "WegoFulfill",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.wegofulfill.com/images/logo.png"
      }
    }
  })} />

  <Footer slot="footer" />
</BaseLayout>

<style>
  .content-container { max-width: 800px; }
  .breadcrumb { font-size: 0.9rem; color: var(--color-text-light); margin-bottom: 2rem; }
  .breadcrumb a { color: var(--color-primary); }

  .content-header { margin-bottom: 3rem; }
  .content-meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-light);
    flex-wrap: wrap;
  }
  .content-category {
    background: rgba(249,115,22,0.1);
    color: var(--color-accent);
    padding: 0.2rem 0.75rem;
    border-radius: 50px;
    font-weight: 600;
  }
  .content-header h1 { font-size: 2.25rem; margin-bottom: 1rem; }
  .content-desc { font-size: 1.1rem; color: var(--color-text-light); line-height: 1.8; }
  .content-author { display: block; margin-top: 0.75rem; font-size: 0.9rem; color: var(--color-text-light); font-weight: 500; }

  .content-body { line-height: 1.9; }
  .content-body h2 { margin: 2.5rem 0 1rem; font-size: 1.5rem; }
  .content-body h3 { margin: 1.5rem 0 0.75rem; font-size: 1.2rem; }
  .content-body p { margin-bottom: 1.25rem; color: var(--color-text); }
  .content-body ul { margin-bottom: 1.25rem; padding-left: 1.5rem; list-style: disc; }
  .content-body li { margin-bottom: 0.5rem; color: var(--color-text); }
  .content-body table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; }
  .content-body th, .content-body td { padding: 0.75rem 1rem; text-align: left; border: 1px solid var(--color-border); }
  .content-body th { background: var(--color-bg-alt); font-weight: 700; }
  .content-body strong { color: var(--color-primary-dark); }
  @media (max-width: 576px) {
    .content-header h1 { font-size: 1.5rem; }
    .content-body { font-size: 0.95rem; }
    .content-body h2 { font-size: 1.25rem; }
  }
</style>
